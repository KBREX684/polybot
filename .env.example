# Core
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# Generator (OpenAI)
GENERATOR_MODEL=gpt-4o-mini
GENERATOR_API_KEY=
GENERATOR_BASE_URL=
GENERATOR_TEMPERATURE=0.2

# Discriminator (Zhipu OpenAI-compatible)
DISCRIMINATOR_MODEL=glm-4.7
DISCRIMINATOR_API_KEY=
DISCRIMINATOR_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
DISCRIMINATOR_TEMPERATURE=0.01

# Runtime
ALLOW_MOCK_LLM=true
DEFAULT_BANKROLL_USDC=10000
MAX_MARKETS_PER_CYCLE=30
PAPER_LEDGER_PATH=logs/paper_trades.jsonl
DECISION_LOG_PATH=logs/decisions.jsonl
CYCLE_LOG_PATH=logs/cycles.jsonl

# GraphRAG storage (Postgres + pgvector + graph relation tables)
GRAPH_RAG_PG_DSN=
GRAPH_RAG_TOP_K=8

# Serper news source
SERPER_API_KEY=
SERPER_ENDPOINT=https://google.serper.dev/news
SERPER_GL=us
SERPER_HL=en
SERPER_NUM=8

# Hard filter
MIN_LIQUIDITY_USDC=3000
MAX_SPREAD=0.05
MIN_HOURS_TO_END=0
MAX_HOURS_TO_END=2160

# Risk (balanced)
MIN_NET_EDGE=0.035
MAX_SINGLE_MARKET_ALLOCATION=0.025
MIN_TRADE_USDC=10
KELLY_FRACTION=0.25

# Transaction costs (Polymarket fees)
TRANSACTION_FEE_PCT=0.02
EXIT_FEE_PCT=0.02

# Volatility adjustment (time-horizon proxy)
VOLATILITY_HIGH_THRESHOLD=0.15
VOLATILITY_MED_THRESHOLD=0.10
VOLATILITY_HIGH_MIN_MULT=0.4
VOLATILITY_MED_MIN_MULT=0.6

# Portfolio / category exposure
MAX_CATEGORY_EXPOSURE_PCT=0.35
MAX_CORRELATED_POSITIONS=4

# Exposed previously-hardcoded values
MAX_OPEN_POSITIONS=25
MIN_CONFIDENCE=0.55
EXTREME_PRICE_ZONE_LOW=0.01
EXTREME_PRICE_ZONE_HIGH=0.99
EDGE_REVERSAL_THRESHOLD=0.02

# Market filtering extras
MIN_IMPLIED_PROBABILITY=0.05
MIN_VOLUME_USDC=1000

# Time decay
NEAR_RESOLUTION_HOURS=48
NEAR_RESOLUTION_EDGE_BOOST=0.15
EARLY_MARKET_UNCERTAINTY_PENALTY=0.10
EARLY_MARKET_DAYS_THRESHOLD=60

# Kill switch — set to true for emergency halt
KILL_SWITCH=false

# Drawdown heat system
MAX_DRAWDOWN_PCT=0.20
WARNING_DRAWDOWN_PCT=0.10
CRITICAL_DRAWDOWN_PCT=0.15
AUTO_KILL_AT_MAX=true

# Daily loss limit (USDC)
MAX_DAILY_LOSS_USDC=500

# Position management
STOP_LOSS_PCT=0.20
TAKE_PROFIT_PCT=0.30
MAX_HOLD_HOURS=336

# Calibration
CALIBRATION_EXTREME_THRESHOLD=0.15
CALIBRATION_EVIDENCE_PENALTY_WEIGHT=0.30
CALIBRATION_CONTRADICTION_PENALTY_WEIGHT=0.20
CALIBRATION_AUTO_RETRAIN_AFTER=30

# API cache TTL (seconds)
GAMMA_CACHE_TTL_SECONDS=300
SERPER_CACHE_TTL_SECONDS=3600

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=2345
DASHBOARD_API_KEY=

# Fixed cycle scheduling
CYCLE_INTERVAL_SECONDS=900
RECOMMENDED_CYCLE_INTERVAL_SECONDS=900

# Whale tracker (P2-1)
WHALE_ENABLED=false
WHALE_MAX_WALLETS=20
WHALE_MIN_CONVICTION=15.0
WHALE_EDGE_BOOST=0.03
WHALE_EDGE_PENALTY=0.015

# SQLite storage (P2-4)
DB_PATH=data/polybot.db

# Alerts (P2-3)
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_DISCORD_WEBHOOK=
ALERT_SLACK_WEBHOOK=
ALERT_COOLDOWN_SECONDS=300

# Logging
LOG_LEVEL=INFO
